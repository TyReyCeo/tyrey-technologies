# --- Database ---
# Local dev default is SQLite. For production use Postgres (Supabase / Neon / RDS):
# DATABASE_URL=postgresql://user:password@host:5432/tyrey_db
DATABASE_URL=sqlite:///./tyrey.db

# --- AI Engine ---
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-5

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string
# Comma-separated emails allowed to use admin endpoints (lead listing).
# Empty = admin routes are locked for everyone.
ADMIN_EMAILS=

# --- Stripe (funnel one-time packs + SaaS subscriptions) ---
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# Stripe -> Developers -> Webhooks (endpoint: POST /funnel/webhook,
# events: checkout.session.completed, customer.subscription.deleted)
STRIPE_WEBHOOK_SECRET=
# Recurring price IDs for SaaS tiers (create in Stripe Dashboard -> Products)
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_EXECUTIVE=
# TyRey Connect AI subscription tiers (Connect $495/mo, Connect Executive $995/mo)
STRIPE_PRICE_CONNECT=
STRIPE_PRICE_CONNECT_EXECUTIVE=

# --- TyRey Connect AI (carrier layer) ---
# demo (default, simulated sends — no keys) | twilio
CONNECT_PROVIDER=demo
# Required only when CONNECT_PROVIDER=twilio. The auth token also verifies
# inbound webhook signatures (Twilio signs with it — there is no separate
# webhook secret).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Per-user outbound send rate limit (messages per minute)
CONNECT_SEND_RATE_PER_MIN=60

# --- URLs ---
FRONTEND_URL=http://localhost:3000
