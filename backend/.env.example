# --- Database ---
# Local dev default is SQLite. For production use Postgres (Supabase / Neon / RDS):
# DATABASE_URL=postgresql://user:password@host:5432/tyrey_db
DATABASE_URL=sqlite:///./tyrey.db

# --- AI Engine ---
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-5

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string

# --- Stripe (funnel one-time packs + SaaS subscriptions) ---
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# Stripe -> Developers -> Webhooks (endpoint: POST /funnel/webhook, event: checkout.session.completed)
STRIPE_WEBHOOK_SECRET=
# Recurring price IDs for SaaS tiers (create in Stripe Dashboard -> Products)
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_EXECUTIVE=

# --- URLs ---
FRONTEND_URL=http://localhost:3000
